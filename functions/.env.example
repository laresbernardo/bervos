# GitHub Personal Access Token (for fetching stars, issues, versions)
# Create one at https://github.com/settings/tokens
GITHUB_TOKEN=your_github_token_here

# JSON string mapping of project IDs to their service account JSON key structures.
# Example format:
# FIREBASE_PROJECTS_CONFIG='{"bilio-c70af": {"type": "service_account", "project_id": "bilio-c70af", "private_key": "-----BEGIN PRIVATE KEY-----\\n...", "client_email": "..."}, "aura-bervos": {...}}'
FIREBASE_PROJECTS_CONFIG='{}'
